# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public app URL (used in metadata + email redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# hCaptcha — optional, but enable for production
# 1. Sign up free at https://www.hcaptcha.com → get site + secret keys
# 2. Paste sitekey here, secret in Supabase Auth → Bot Protection → hCaptcha
# When unset: hCaptcha widget is hidden in dev.
NEXT_PUBLIC_HCAPTCHA_SITEKEY=

# Sentry — optional, but enable for production error tracking
# 1. Sign up free at https://sentry.io → create Next.js project → grab DSN
# 2. The same DSN goes in both vars (one is exposed to the client)
# When unset: Sentry init is a no-op.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Discord webhooks — server-only, NEVER prefix with NEXT_PUBLIC_
# Setup: Discord channel → Edit → Integrations → Webhooks → New Webhook → Copy URL
# All vars are optional; missing vars are silently skipped (app never crashes).
# Store URLs in Vercel env (Production + Preview + Development). Never commit them.
#
# Per-channel bots:
#   DISCORD_ACTIVITY_WEBHOOK_URL  → #cl-activity  (Collective Activity Bot)
#   DISCORD_BOOKS_WEBHOOK_URL     → #cl-books      (Collective Books Bot)
#   DISCORD_MAP_WEBHOOK_URL       → #cl-map        (Collective Map Bot)
#   DISCORD_EVENTS_WEBHOOK_URL    → #cl-events     (Collective Events Bot)
#   DISCORD_FEEDBACK_WEBHOOK_URL  → #cl-feedback   (Collective Feedback Bot)
#   DISCORD_SYSTEM_WEBHOOK_URL    → #cl-system     (Collective System Bot)
#   DISCORD_TEST_WEBHOOK_URL      → #cl-test-webhook (Collective Test Bot)
#
# Event routing:
#   USER_JOINED, WTB_POSTED, MANIFEST_POSTED → activity
#   BOOK_ADDED, BOOK_STATUS_CHANGED          → books + activity
#   EVENT_CREATED                            → events + activity
#   EVENT_RSVPED                             → events
#   NODE_CREATED (Spots)                     → map + activity
#   feedback_submitted                       → feedback (via /api/feedback directly)
#   event manual announce                    → events (via /api/events/[id]/announce)
#
# Shared secret — generate with: openssl rand -hex 32
# Set the same value in Supabase Dashboard → Database → Webhooks → HTTP headers:
#   Authorization: Bearer <DISCORD_WEBHOOK_SECRET>
DISCORD_ACTIVITY_WEBHOOK_URL=
DISCORD_BOOKS_WEBHOOK_URL=
DISCORD_MAP_WEBHOOK_URL=
DISCORD_EVENTS_WEBHOOK_URL=
DISCORD_FEEDBACK_WEBHOOK_URL=
DISCORD_SYSTEM_WEBHOOK_URL=
DISCORD_TEST_WEBHOOK_URL=
DISCORD_WEBHOOK_SECRET=
# Legacy — accepted as fallback for "activity" channel during Supabase webhook migration:
DISCORD_COMMUNITY_WEBHOOK_URL=
